    title: \"IMDB ID\",\n      type: \"string\",\n      description: \"IMDB identifier (e.g., tt1234567)\",\n    }),\n    defineField({\n      name: \"year\",\n      title: \"Release Year\",\n      type: \"number\",\n      description: \"Year the film was released\",\n      validation: Rule => Rule.min(1900).max(new Date().getFullYear() + 5),\n    }),\n    defineField({\n      name: \"director\",\n      title: \"Director\",\n      type: \"string\",\n      description: \"Film director\",\n    }),\n    defineField({\n      name: \"cast\",\n      title: \"Cast\",\n      type: \"array\",\n      description: \"Key cast members\",\n      of: [{ type: \"string\" }],\n    }),\n    defineField({\n      name: \"runtime\",\n      title: \"Runtime (minutes)\",\n      type: \"number\",\n      description: \"Film duration in minutes\",\n      validation: Rule => Rule.min(1).max(600),\n    }),\n    defineField({\n      name: \"certificate\",\n      title: \"Certificate\",\n      type: \"string\",\n      description: \"Age rating/classification\",\n      options: {\n        list: [\n          { title: \"U\", value: \"U\" },\n          { title: \"PG\", value: \"PG\" },\n          { title: \"12A\", value: \"12A\" },\n          { title: \"15\", value: \"15\" },\n          { title: \"18\", value: \"18\" },\n        ],\n      },\n    }),\n    defineField({\n      name: \"genre\",\n      title: \"Genres\",\n      type: \"array\",\n      description: \"Film genres\",\n      of: [{ type: \"string\" }],\n    }),\n    defineField({\n      name: \"plot\",\n      title: \"Plot\",\n      type: \"text\",\n      description: \"Film plot summary\",\n      rows: 4,\n    }),\n    defineField({\n      name: \"poster\",\n      title: \"Film Poster\",\n      type: \"image\",\n      options: {\n        hotspot: true,\n      },\n      fields: [\n        defineField({\n          name: \"alt\",\n          type: \"string\",\n          title: \"Alt text\",\n          description: \"Alternative text for screenreaders\",\n        }),\n      ],\n    }),\n    defineField({\n      name: \"imdbUrl\",\n      title: \"IMDB URL\",\n      type: \"url\",\n      description: \"Link to IMDB page\",\n    }),\n    defineField({\n      name: \"dateAddedToWishlist\",\n      title: \"Date Added to Wishlist\",\n      type: \"date\",\n      description: \"When this film was added to the wishlist\",\n    }),\n    defineField({\n      name: \"dateWatched\",\n      title: \"Date Watched\",\n      type: \"date\",\n      description: \"When you watched this film\",\n      hidden: ({ document }) => document?.status !== \"watched\",\n    }),\n    defineField({\n      name: \"cinemaLocation\",\n      title: \"Cinema Location\",\n      type: \"string\",\n      description: \"Which Cineworld cinema you watched this at\",\n      hidden: ({ document }) => document?.status !== \"watched\",\n    }),\n    defineField({\n      name: \"personalRating\",\n      title: \"Personal Rating\",\n      type: \"number\",\n      description: \"Your personal rating (1-5)\",\n      validation: Rule => Rule.min(1).max(5).integer(),\n      hidden: ({ document }) => document?.status !== \"watched\",\n    }),\n    defineField({\n      name: \"personalNotes\",\n      title: \"Personal Notes\",\n      type: \"text\",\n      description: \"Your thoughts and notes about the film\",\n      rows: 4,\n      hidden: ({ document }) => document?.status !== \"watched\",\n    }),\n  ],\n});",
