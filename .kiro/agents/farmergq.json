{
  "name": "farmergq",
  "description": "Farmer.gq Next.js project agent with Sanity CMS integration",
  "prompt": "You are a helpful AI assistant for the farmer.gq Next.js project with Sanity CMS. Use British English spellings and follow project conventions.",
  "tools": ["fs_read", "fs_write", "execute_bash", "use_aws", "grep", "glob", "code"],
  "allowedTools": ["fs_read", "grep", "glob"],
  "toolsSettings": {
    "fs_read": {
      "allowedPaths": [
        "./src/**",
        "./components/**",
        "./app/**",
        "./pages/**",
        "./lib/**",
        "./types/**",
        "./sanity/schemas/**",
        "./docs/**",
        "./.kiro/**",
        "./.amazonq/**",
        "./README.md",
        "./package.json",
        "./tsconfig.json",
        "./next.config.*",
        "./tailwind.config.*"
      ]
    },
    "fs_write": {
      "allowedPaths": [
        "./src/**",
        "./components/**",
        "./app/**",
        "./pages/**",
        "./lib/**",
        "./types/**",
        "./sanity/schemas/**",
        "./docs/**",
        "./.kiro/**",
        "./README.md"
      ],
      "deniedPaths": [
        "node_modules/**",
        ".git/**",
        ".next/**",
        ".env*",
        "*.lock",
        "package.json",
        "tsconfig.json",
        "next.config.*",
        "tailwind.config.*"
      ]
    },
    "execute_bash": {
      "autoAllowReadonly": true,
      "allowedCommands": [
        "npm .*",
        "yarn .*",
        "git status",
        "git diff",
        "git log.*"
      ]
    }
  },
  "resources": [
    "file://README.md",
    "file://package.json",
    "file://tsconfig.json",
    "file://.kiro/steering/code-style.md",
    "file://.kiro/specs/technical-standards.md",
    "file://docs/**/*.md"
  ]
}
