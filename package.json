{
  "name": "farmer.gq-next.js",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run typegen && next build && sanity manifest extract --path public/studio/static",
    "predev": "npm run typegen",
    "clean": "rm -rf .next",
    "dev-old": "next dev",
    "dev": "next dev --turbopack",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "lint:dry-run": "eslint . --fix-dry-run",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "typegen": "sanity schema extract && sanity typegen generate",
    "sanity-build": "sanity build",
    "sanity-deploy": "sanity deploy",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:auth": "vitest --run --reporter=verbose auth",
    "test:films": "vitest --run --reporter=verbose film",
    "test:books": "vitest --run --reporter=verbose book",
    "test:watch:auth": "vitest --reporter=verbose auth",
    "test:watch:films": "vitest --reporter=verbose film",
    "prepare": "husky"
  },
  "dependencies": {
    "@heroui/react": "2.8.10",
    "@next/env": "^16.2.6",
    "@sanity/block-content-to-react": "3.0.0",
    "@sanity/client": "^7.22.0",
    "@sanity/code-input": "7.0.11",
    "@sanity/image-url": "2.0.3",
    "@sanity/react-loader": "^2.0.10",
    "@sanity/schema": "^5.25.1",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^5.25.1",
    "@sanity/visual-editing": "^5.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.44.0",
    "@tailwindcss/typography": "0.5.19",
    "better-auth": "^1.6.11",
    "classnames": "2.5.1",
    "date-fns": "4.1.0",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "next-sanity": "^12.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "5.6.0",
    "react-is": "^19.2.6",
    "react-live-transitions": "0.2.0",
    "react-syntax-highlighter": "16.1.1",
    "rxjs": "7.8.2",
    "sanity": "^5.25.1",
    "sanity-plugin-asset-source-unsplash": "7.0.5",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "styled-components": "6.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@sanity/mcp-server": "^0.12.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "autoprefixer": "10.4.27",
    "babel-plugin-react-compiler": "beta",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "husky": "9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "next-devtools-mcp": "latest",
    "postcss": "^8.5.14",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
