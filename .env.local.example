# Sanity Configuration - Required
# Get tokens from https://manage.sanity.io or check LastPass notes
NEXT_PUBLIC_SANITY_PROJECT_ID="ix9xb2vm"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_DATASET="production"
SANITY_API_PROJECT_ID="ix9xb2vm"
SANITY_STUDIO_DATASET="production"
SANITY_STUDIO_PROJECT_ID="ix9xb2vm"

# Sanity API Tokens - Required for MCP servers
# Read token: For querying content
SANITY_API_READ_TOKEN="your-read-token-here"
# Write token: For creating/updating content
SANITY_API_WRITE_TOKEN="your-write-token-here"

# Next.js Configuration
NEXT_PAGE_SIZE=15

# OMDb API for film metadata
OMDB_API_KEY=your_omdb_api_key_here

# Legacy Gatsby variables (can be removed when fully migrated)
SANITY_TOKEN="your-legacy-token-here"
GATSBY_PAGE_SIZE=2
GATSBY_HOT_LOADER=fast-refresh
GATSBY_GRAPHQL_ENDPOINT="https://ix9xb2vm.api.sanity.io/v1/graphql/production/default"
GATSBY_SERVERLESS_BASE=http://localhost:8888/.netlify/functions

# Development/Testing
TEST_ANDY="🪾 reach out"

# Email Configuration (for contact forms)
MAIL_HOST=smtp.ethereal.email
MAIL_USER="your-email-user"
MAIL_PASS="your-email-password"

# Google OAuth Configuration
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Better Auth Configuration
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Local: http://localhost:3000, Production: https://farmer.gq
BETTER_AUTH_URL="http://localhost:3000"

# Authorisation - Comma-separated list of authorised email addresses
# Example: "andy@example.com,friend@example.com"
AUTHORIZED_EMAILS="your-email@example.com"
